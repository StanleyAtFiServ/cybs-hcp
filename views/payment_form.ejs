<!DOCTYPE html>
<html>
<head>
    <title>Secure Acceptance - Payment Form Example</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" type="text/css" href="/css/payment.css"/>
    <!-- Modern alternative to jQuery -->
    <script src="js/payment_form.js"></script>

    <style>
        /* Beautify the token display */
        #idB64EncText {
            font-family: monospace;
            background-color: #f9f9f9;
            border: 1px solid #ccc;
            padding: 12px;
            margin-top: 10px;
            word-break: break-all;
            white-space: pre-wrap;
            border-radius: 6px;
            color: #333;
        }
        #idResult {
            margin-top: 20px;
        }
        #idResult h3 {
            font-size: 1.0em;
            color: #0066cc;
            margin-bottom: 8px;
        }
        #legend {
            font-size: 1.2em;
            color: #333;
        }
        #copyBtn {
            margin-top: 8px;
            padding: 6px 12px;
            background-color: #0066cc;
            color: #fff;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }
        #copyBtn:hover {
            background-color: #004c99;
        }
        .note-text {
            font-size: 0.8em;
            color: #555;
            font-family: "Bahnschrift Light Condensed", sans-serif;
            margin:0;
}
    </style>
</head>
<body>
    <form id="payment-confirm" action="/payment/confirm" method="post">
        <input type="hidden" name="access_key" value="<%= accessKey %>">
        <input type="hidden" name="profile_id" value="<%= profileId %>">
        <input type="hidden" name="transaction_uuid" value="<%= transactionUuid %>">
        <input type="hidden" name="signed_field_names" value="access_key,profile_id,transaction_uuid,signed_field_names,unsigned_field_names,signed_date_time,locale,transaction_type,reference_number,amount,currency">
        <input type="hidden" name="unsigned_field_names">
        <input type="hidden" name="signed_date_time" value="<%= signedDateTime %>">
        <input type="hidden" name="locale" value="en">
        
        <fieldset>
            <legend>Host Checkout Page</legend>
            <div id="paymentDetailsSection" class="section">
                <span>transaction_type:</span>
                <input type="text" name="transaction_type" size="25"><br/>
                
                <span>reference_number:</span>
                <input type="text" name="reference_number" size="25"><br/>
                
                <span>amount:</span>
                <input type="text" name="amount" size="25"><br/>
                
                <span>currency:</span>
                <input type="text" name="currency" size="25"><br/>
            </div>
            <input type="submit" id="sumbit" name="submit" value="Submit"/>
        </fieldset>
    </form>

    <fieldset>
        <legend>Request GPay Tokenisation Data</legend>
        <div id="gpay-container"></div>
        <script>
            console.log('Organization ID from EJS: <%= organizationId %>');
            const environment = {
                merchantId: "<%= organizationId %>",  // Required for PRODUCTION environment
                merchantName: "<%= organizationName %>"  // Required for both environments, but can be the same as merchantId for TEST environment
            };
        </script>
        <script type="text/javascript" src="js/gpay.js"></script>

        <script
            async src="https://pay.google.com/gp/p/js/pay.js"
            onload="onGooglePayLoaded()">
        </script>
                
        <div id="idResult">
            <h3>Encoded Payment Tokenisation Data</h3>
            <p id="idB64EncText"></p>
            <div style="display:flex; align-items:flex-end; gap:10px;">
                <button id="copyBtn" onclick="copyToken()">Copy Token</button>
                <p class="note-text">
                Apply for API request field paymentInformation.fluidData.value.
                </p>
            </div>
        </div>

    </fieldset>

    <!-- Modern JavaScript replacement for payment_form.js -->
    <script>
        document.getElementById("payment-confirm").addEventListener("submit", function (e) {
            document.getElementById("idTransactionUuid").value = crypto.randomUUID();
            document.getElementById("idSignedDateTime").value = new Date().toISOString();
            console.log("Debug : " + document.getElementById("idProfileId").value);
        });

        function copyToken() {
            const text = document.getElementById("idB64EncText").innerText;
            if (text) {
                navigator.clipboard.writeText(text).then(() => {
                    alert("Token copied to clipboard!");
                });
            }
        }
    </script>
</body>
</html>
